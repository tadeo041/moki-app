generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rentals   Rental[]
}

model Motorcycle {
  id              String   @id @default(cuid())
  name            String
  pricePerHour    Float
  cc              Int
  year            Int
  imageUrl        String
  status          Status   @default(AVAILABLE)
  maxSpeed        String
  mileage         String
  consumption     String
  type            String
  cylinders       String
  brakes          String
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  rentals         Rental[]
}

model Rental {
  id                String         @id @default(cuid())
  userId            String
  motorcycleId      String
  startDate         DateTime
  endDate           DateTime
  totalDays         Int
  totalPrice        Float
  status            RentalStatus   @default(PENDING)
  paymentStatus     PaymentStatus  @default(PENDING)
  paymentIntentId   String?        @unique
  insurance         Boolean        @default(false)
  helmetKit         Boolean        @default(false)
  delivery          Boolean        @default(false)
  cardName          String
  cardNumber        String
  cardExpiry        String
  cardCVV           String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User           @relation(fields: [userId], references: [id])
  motorcycle        Motorcycle     @relation(fields: [motorcycleId], references: [id])
}

enum Status {
  AVAILABLE
  RENTED
  MAINTENANCE
}

enum RentalStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}